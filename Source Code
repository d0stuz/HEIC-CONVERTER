# ── Yardımcı widget'lar ────────────────────────────────────────────────────────
class HoverButton(tk.Button):
    def __init__(self, master, bg_normal, bg_hover, **kw):
        super().__init__(master, bg=bg_normal, activebackground=bg_hover,
                         relief="flat", cursor="hand2", **kw)
        self._bg_normal = bg_normal
        self._bg_hover  = bg_hover
        self.bind("<Enter>", lambda e: self.config(bg=bg_hover) if self['state'] != 'disabled' else None)
        self.bind("<Leave>", lambda e: self.config(bg=bg_normal))

class Section(tk.Frame):
    def __init__(self, master, title, **kw):
        super().__init__(master, bg=CARD, bd=0, **kw)
        self.config(highlightbackground=BORDER, highlightthickness=1)
        header = tk.Frame(self, bg=SURFACE, pady=8)
        header.pack(fill="x")
        tk.Label(header, text=title, font=FONT_H2, fg=ACCENT2,
                 bg=SURFACE, padx=16).pack(side="left")
        self.body = tk.Frame(self, bg=CARD, padx=16, pady=12)
        self.body.pack(fill="both", expand=True)

class PathRow(tk.Frame):
    def __init__(self, master, label, btn_text, mode="dir", **kw):
        super().__init__(master, bg=CARD, **kw)
        self._mode = mode
        tk.Label(self, text=label, font=FONT_SMALL, fg=MUTED,
                 bg=CARD, width=14, anchor="w").pack(side="left")
        self.var = tk.StringVar()
        entry = tk.Entry(self, textvariable=self.var, font=FONT_MONO,
                         bg=SURFACE, fg=TEXT, insertbackground=TEXT,
                         relief="flat", bd=6, highlightthickness=1,
                         highlightbackground=BORDER,
                         highlightcolor=ACCENT)
        entry.pack(side="left", fill="x", expand=True)
        HoverButton(self, bg_normal=BORDER, bg_hover=ACCENT,
                    text=btn_text, font=FONT_SMALL, fg=WHITE,
                    command=self._pick).pack(side="left", padx=(6, 0))

    def _pick(self):
        if self._mode == "dir":
            p = filedialog.askdirectory()
        elif self._mode == "files":
            p = filedialog.askopenfilenames(
                filetypes=[("HEIC files", "*.heic *.HEIC *.heif *.HEIF"),
                           ("All files", "*.*")])
            p = ";".join(p) if p else ""
        if p:
            self.var.set(p)

    def get(self):
        return self.var.get()

