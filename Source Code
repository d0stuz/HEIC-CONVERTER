    # ── UI yardımcıları ────────────────────────────────────────────────────────
    def _on_mode_change(self):
        if self.mode_var.get() == "folder":
            self.files_row.pack_forget()
            self.folder_row.pack(fill="x", pady=2)
        else:
            self.folder_row.pack_forget()
            self.files_row.pack(fill="x", pady=2)

    def _on_same_toggle(self):
        if self.same_var.get():
            self.dest_row.pack_forget()
        else:
            self.dest_row.pack(fill="x")

    def _on_fmt_change(self):
        fmt = self.fmt_var.get()
        if fmt in ("jpg", "webp"):
            self.quality_frame.pack(fill="x", pady=(4, 0))
        else:
            self.quality_frame.pack_forget()

        if fmt == "webp":
            self.webp_frame.pack(fill="x", pady=(10, 0))
        else:
            self.webp_frame.pack_forget()

    def _on_lossless_change(self):
        # Lossless seçildiğinde kalite çubuğunu görsel olarak bilgilendirme amaçlı disable edebiliriz.
        pass

    def _on_quality(self, v):
        self.quality_lbl.config(text=str(int(float(v))))

    def _on_pct(self, v):
        self.pct_lbl.config(text=str(int(float(v))))

    def _on_resize_change(self):
        mode = self.resize_var.get()
        self.pct_frame.pack_forget()
        self.dim_frame.pack_forget()
        if mode == "percent":
            self.pct_frame.pack(fill="x")
        elif mode == "maxdim":
            self.dim_frame.pack(fill="x")

    def _log(self, msg, tag=""):
        ts = time.strftime("%H:%M:%S")
        self.log_text.config(state="normal")
        self.log_text.insert("end", f"[{ts}] {msg}\n", tag)
        self.log_text.see("end")
        self.log_text.config(state="disabled")

    def _set_status(self, msg):
        self.status_lbl.config(text=msg)

    # ── Dönüştürme ─────────────────────────────────────────────────────────────
    def _start(self):
        if self._running: return
        files = self._collect_files()
        if not files:
            messagebox.showwarning("Uyarı / Warning", self.t("warn_no_src"))
            return
        dest = self._resolve_dest(files)
        if dest is None: return
        
        os.makedirs(dest, exist_ok=True)
        settings = {
            "fmt": self.fmt_var.get(), 
            "quality": self.quality_var.get(),
            "resize": self.resize_var.get(), 
            "pct": self.pct_var.get() / 100.0,
            "maxdim": self.dim_var.get(), 
            "dest": dest,
            "webp_lossless": self.lossless_var.get(),
            "trans_mode": self.trans_var.get(),
            "blend_color": "white" if self.blend_cb.get() == self.t("color_white") else "black"
        }
        
        self._running = True
        self.convert_btn.config(state="disabled", text=self.t("btn_processing"))
        self.progress["value"] = 0
        self.progress["maximum"] = len(files)
        threading.Thread(target=self._run, args=(files, settings), daemon=True).start()

    def _collect_files(self):
        if self.mode_var.get() == "folder":
            src = self.folder_row.get().strip()
            if not src or not os.path.isdir(src): return []
            files = []
            for p in ["*.heic", "*.HEIC", "*.heif", "*.HEIF"]:
                files.extend(glob.glob(os.path.join(src, p)))
            return sorted(set(files))
        else:
            raw = self.files_row.get().strip()
            return [f for f in raw.split(";") if os.path.isfile(f)] if raw else []

    def _resolve_dest(self, files):
        if self.same_var.get():
            return os.path.dirname(files[0])
        dest = self.dest_row.get().strip()
        if not dest:
            messagebox.showwarning("Uyarı / Warning", self.t("warn_no_dest"))
            return None
        return dest

    def _run(self, files, s):
        ok = err = 0
        dest_folder = s["dest"]
        for i, path in enumerate(files):
            name = os.path.basename(path)
            try:
                img = Image.open(path)
                try: img = ImageOps.exif_transpose(img)
                except Exception: pass

                if s["resize"] == "percent":
                    w, h = int(img.width * s["pct"]), int(img.height * s["pct"])
                    img = img.resize((w, h), Image.LANCZOS)
                elif s["resize"] == "maxdim":
                    maxd = s["maxdim"]
                    if max(img.width, img.height) > maxd:
                        img.thumbnail((maxd, maxd), Image.LANCZOS)

                stem = os.path.splitext(name)[0]
                ext = s["fmt"]
                out_path = os.path.join(dest_folder, f"{stem}.{ext}")

                save_kw = {}
                
                # Format Bazlı Kaydetme Seçenekleri
                if s["fmt"] == "jpg":
                    if img.mode in ("RGBA", "LA", "P"): img = img.convert("RGB")
                    save_kw = {"quality": s["quality"], "optimize": True}
                
                elif s["fmt"] == "png":
                    save_kw = {"optimize": True}
                
                elif s["fmt"] == "webp":
                    # WebP Şeffaflık (Alpha) Ayarları
                    if img.mode in ("RGBA", "LA", "P", "PA"):
                        img = img.convert("RGBA")
                        if s["trans_mode"] == "blend":
                            c = (255, 255, 255) if s["blend_color"] == "white" else (0, 0, 0)
                            bg = Image.new("RGBA", img.size, c)
                            bg = Image.alpha_composite(bg, img)
                            img = bg.convert("RGB") # Şeffaflık ezildi
                        elif s["trans_mode"] == "opaque":
                            bg = Image.new("RGBA", img.size, (0, 0, 0))
                            bg = Image.alpha_composite(bg, img)
                            img = bg.convert("RGB") # Siyahla doldurulup alfa atıldı
                    
                    save_kw = {
                        "quality": s["quality"], 
                        "lossless": s["webp_lossless"],
                        "method": 4 # Optimum hız/boyut oranı
                    }

                img.save(out_path, **save_kw)
                
                orig_kb, new_kb = os.path.getsize(path) // 1024, os.path.getsize(out_path) // 1024
                self.after(0, self._log, f"✔ {name}  ({orig_kb} KB → {new_kb} KB)", "ok")
                ok += 1
            except Exception as exc:
                self.after(0, self._log, f"✘ {name}  — {exc}", "err")
                err += 1

            self.after(0, self._tick, i + 1, len(files), name)

        self.after(0, self._finish, ok, err, dest_folder)

    def _tick(self, done, total, name):
        self.progress["value"] = done
        pct = int(done / total * 100)
        self._set_status(f"{done}/{total}  ({pct}%)  —  {name}")

    def _finish(self, ok, err, dest_folder):
        self._running = False
        self.convert_btn.config(state="normal", text=self.t("btn_convert"))
        msg = f"{self.t('msg_done')} — {ok} {self.t('msg_success')}"
        if err: msg += f", {err} {self.t('msg_err')}"
        
        self._log("─" * 50, "info")
        self._log(msg, "ok" if not err else "warn")
        self._set_status(msg)
        self.progress["value"] = self.progress["maximum"]
        
        if self.open_var.get() and os.path.exists(dest_folder):
            try:
                os.startfile(dest_folder)
            except Exception as e:
                self._log(f"Klasör açılamadı: {e}", "err")

